{
  "entities": {
    "Lecture": {
      "title": "Lecture",
      "description": "A lecture document containing metadata and a link to the PDF file.",
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "description": "The title of the lecture."
        },
        "category": {
          "type": "string",
          "enum": ["pharmacology", "pharmacognosy", "organic_chemistry", "biochemistry", "cosmetics"],
          "description": "The subject category of the lecture."
        },
        "type": {
          "type": "string",
          "enum": ["theoretical", "practical"],
          "description": "Whether the lecture is theoretical or practical."
        },
        "description": {
          "type": "string",
          "description": "A brief description of the lecture content."
        },
        "pdfUrl": {
          "type": "string",
          "format": "uri",
          "description": "The URL to the PDF file."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp when the lecture was uploaded."
        },
        "uploadedBy": {
          "type": "string",
          "description": "The UID of the admin who uploaded the lecture."
        }
      },
      "required": ["title", "category", "type", "pdfUrl", "createdAt", "uploadedBy"]
    },
    "User": {
      "title": "User",
      "description": "User profile information and roles.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "role": {
          "type": "string",
          "enum": ["admin", "student"],
          "description": "The role of the user."
        }
      },
      "required": ["name", "email", "role"]
    },
    "Announcement": {
      "title": "Announcement",
      "description": "An announcement post, potentially synced from Telegram.",
      "type": "object",
      "properties": {
        "text": {
          "type": "string",
          "description": "The text content of the announcement."
        },
        "content": {
          "type": "string",
          "description": "Alias for text (backward compatibility)."
        },
        "type": {
          "type": "string",
          "enum": ["text", "image", "video"],
          "description": "The type of announcement content."
        },
        "imageUrl": {
          "type": "string",
          "format": "uri",
          "description": "Optional URL for an image."
        },
        "videoUrl": {
          "type": "string",
          "format": "uri",
          "description": "Optional URL for a video."
        },
        "date": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp of the announcement."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Alias for date (backward compatibility)."
        },
        "createdBy": {
          "type": "string",
          "description": "The source or user who created the announcement."
        },
        "authorName": {
          "type": "string",
          "description": "The name of the author (e.g., Telegram Channel)."
        }
      },
      "required": ["type", "createdBy", "authorName"]
    }
  },
  "firestore": {
    "/lectures/{lectureId}": {
      "schema": "Lecture",
      "description": "Collection of all lectures."
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of user profiles."
    },
    "/announcements/{announcementId}": {
      "schema": "Announcement",
      "description": "Collection of announcements and notifications."
    }
  }
}
