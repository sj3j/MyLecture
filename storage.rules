rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdminOrModerator() {
      return isAuthenticated() && 
        firestore.exists(/databases/(default)/documents/users/$(request.auth.uid)) &&
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role in ['admin', 'moderator'];
    }

    // Profile pictures: Any user can upload their own
    match /profiles/{fileName} {
      allow read: if true;
      allow write: if isAuthenticated() && fileName.matches(request.auth.uid + ".*");
    }

    // Lectures: Only admins/moderators can upload
    match /lectures/{fileName} {
      allow read: if isAuthenticated();
      allow write: if isAdminOrModerator();
    }

    // Announcements: Only admins/moderators can upload
    match /announcements/{fileName} {
      allow read: if isAuthenticated();
      allow write: if isAdminOrModerator();
    }
    
    // Weekly Tasks: Only admins/moderators can upload
    match /weekly_tasks/{fileName} {
      allow read: if isAuthenticated();
      allow write: if isAdminOrModerator();
    }

    // Chat Attachments: Authenticated users can upload their own files
    match /chat_attachments/{fileName} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && fileName.matches(request.auth.uid + ".*");
    }

    // Default fallback
    match /{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isAdminOrModerator();
    }
  }
}
